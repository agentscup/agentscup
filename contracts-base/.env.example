# ── Deployer ───────────────────────────────────────
# Private key for the account that deploys & owns the contracts.
# Must hold ~0.005 ETH on Base for gas. Never commit the filled-in .env.
# The deployer also becomes DEFAULT_ADMIN_ROLE on all three contracts by
# default (pack store, marketplace, escrow) — rotate with ADMIN_ADDRESS
# if you want the admin to live on a different key.
DEPLOYER_PRIVATE_KEY=

# ── Treasury + admin ───────────────────────────────
# Wallet that RECEIVES pack revenue and marketplace fees.
# Pre-filled with the production treasury; change only if redirecting.
TREASURY_ADDRESS=0x5794F733eE53DfFdbd023ba91d357D8aA334E414

# Optional — override who holds DEFAULT_ADMIN_ROLE on the contracts.
# Leave empty to fall back to the deployer address.
ADMIN_ADDRESS=

# Marketplace fee in basis points (250 = 2.5%). Capped at 500 (5%).
MARKETPLACE_FEE_BPS=250

# ── RPC endpoints ──────────────────────────────────
# Public Base RPC is rate-limited; use Alchemy / Infura / QuickNode for prod.
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Block explorer verification ────────────────────
# https://basescan.org/myapikey
BASESCAN_API_KEY=
