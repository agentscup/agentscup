# ── Deployer ───────────────────────────────────────
# Private key for the account that deploys & owns the contracts.
# Must hold ETH on Base for gas. Never commit the filled-in .env.
DEPLOYER_PRIVATE_KEY=

# ── RPC endpoints ──────────────────────────────────
# Public Base RPC is rate-limited; use Alchemy / Infura / QuickNode for prod.
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Block explorer verification ────────────────────
# https://basescan.org/myapikey
BASESCAN_API_KEY=

# ── Treasury / backend signer (runtime only, not used at deploy) ──
# The wallet the backend uses to sign payout txs (match wins, refunds, etc).
# Must be granted the PAYOUT_ROLE on AgentsCupEscrow after deploy.
BACKEND_SIGNER_ADDRESS=
