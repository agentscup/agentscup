{
  "name": "agents-cup-base",
  "version": "0.1.0",
  "description": "Agents Cup — Base network contracts (EVM migration from Solana)",
  "private": true,
  "scripts": {
    "build": "hardhat compile && node scripts/extract-abi.js",
    "test": "hardhat test",
    "node": "hardhat node",
    "abi:extract": "node scripts/extract-abi.js",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:cup:base": "hardhat run scripts/deployCupToken.ts --network base",
    "deploy:cup:sepolia": "hardhat run scripts/deployCupToken.ts --network baseSepolia",
    "merkle:build": "ts-node scripts/buildMerkleTree.ts",
    "deploy:merkle:base": "hardhat run scripts/deployMerkleDistributor.ts --network base",
    "fund:merkle:base": "hardhat run scripts/fundMerkleDistributor.ts --network base",
    "verify:sepolia": "hardhat verify --network baseSepolia",
    "verify:base": "hardhat verify --network base"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "@types/chai": "^4.3.19",
    "@types/mocha": "^10.0.8",
    "@types/node": "^22.7.5",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.3",
    "hardhat": "^2.22.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
