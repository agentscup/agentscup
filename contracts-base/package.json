    "verify:base": "hardhat verify --network base"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@types/chai": "^4.3.19",
    "@types/mocha": "^10.0.8",
    "@types/node": "^22.7.5",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.3",
    "hardhat": "^2.22.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
